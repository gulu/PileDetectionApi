{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "File": {
      "Path": "Logs/pile-{Date}.log",
      "RetentionDays": 30
    },
    "Table": true
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=dbdata/pile.db"
  },
  "Jwt": {
    "Secret": "PileDetection_DefaultSecret_ChangeInProduction_32Char!",
    "Issuer": "PileDetectionApi",
    "Audience": "PileDetectionClient",
    "ExpireMinutes": 1440
  },
  "Admin": {
    "MasterKey": "admin-master-key-2026-pile-detection"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "AllowedHosts": "*"
}
